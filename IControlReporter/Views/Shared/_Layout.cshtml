<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IControlReporter</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- 引入 Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IControlReporter.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --sidebar-bg: #E8D8FA;       /* 側邊欄主要背景色 */
        --sidebar-hover: #D0B4F2;    /* 滑鼠停靠時的按鈕背景色 */
        --sidebar-text: #4E63A5;     /* 側邊欄文字與圖示統一顏色 */
    }
    .custom-sidebar {
        background-color: var(--sidebar-bg) !important;
        box-shadow: 4px 0 15px rgba(78, 99, 165, 0.05); /* 帶有微微藍紫色的高級陰影 */
        z-index: 1030;
    }
    .sidebar-link {
        transition: all 0.2s ease-in-out;
        color: var(--sidebar-text) !important;
        font-weight: 500;            /* 讓字體稍微加粗，等同圖片質感 */
        border-radius: 30px;         /* 圓角按鈕 */
        padding: 12px 16px !important; /* 增加按鈕內襯空間 */
    }
    /* 關鍵：強制讓 Bootstrap 內建圖示跟著文字一起變色 */
    .sidebar-link i {
        color: var(--sidebar-text) !important;
        opacity: 0.9;
    }
    .sidebar-link:hover {
        background-color: var(--sidebar-hover) !important;
        transform: translateX(3px);  /* 微微右移即可，不宜過大 */
    }
    .sidebar-link:active {
        transform: scale(0.98);
    }
</style>
</head>
<body class="m-0 overflow-hidden">
    <div class="d-flex" style="height: 100vh; max-height: 100vh; overflow: hidden;">
        
        <div class="d-flex flex-column flex-shrink-0 custom-sidebar p-3" style="width: 300px; height: 100%; max-height: 100vh;">
            
            <div class="d-flex align-items-center p-3 mb-2 border-bottom" style="border-color: rgba(255,255,255,0.1) !important;">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none w-100" style="color: var(--sidebar-text);">
                    <img src="~/images/icon.ico" alt="Logo" class="rounded-circle me-3 shadow-sm" style="height: 60px; width: 60px; object-fit: contain; background-color: white; padding: 2px;" />
                    <span class="fs-5 fw-bold" style="letter-spacing: 0.5px;">IControlReport</span>
                </a>
            </div>
            
            <div class="py-2 flex-grow-1 overflow-auto">
                <ul class="nav flex-column mb-auto px-2"> 
                    <li class="nav-item mb-2">
                            <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                                <i class="bi bi-house-door me-4 fs-4"></i>主頁儀表
                            </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a asp-area="" asp-controller="Chart" asp-action="Viewer" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                            <i class="bi bi-graph-up me-4 fs-4"></i>曲線預覽
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a asp-area="" asp-controller="Report" asp-action="Generator" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                            <i class="bi bi-file-earmark-text me-4 fs-4"></i>報表生成
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a asp-area="" asp-controller="PointList" asp-action="Setting" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                            <i class="bi bi-sliders me-4 fs-4"></i>點表對應
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a asp-area="" asp-controller="Event" asp-action="LogHistory" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                            <i class="bi bi-clock-history me-4 fs-4"></i>事件紀錄
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a asp-area="" asp-controller="Setting" asp-action="Setting" class="nav-link fs-5 sidebar-link d-flex align-items-center">
                            <i class="bi bi-gear me-4 fs-4"></i>參數設置
                        </a>
                    </li>
                </ul>
            </div> 
        </div>

        <div class="d-flex flex-column flex-grow-1" style="height: 100%; max-height: 100vh; overflow: hidden;">
            
            <div class="container-fluid p-4 flex-grow-1 overflow-auto">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
